# Vorlage für lokale Entwicklung
# Kopiere diese Datei zu .streamlit/secrets.toml und trage deine echten Werte ein.
# Die Datei secrets.toml wird NICHT in Git eingecheckt.

# Groq API Key (kostenlos unter https://console.groq.com)
GROQ_API_KEY = "gsk_..."

# Passwort für den Zugriff auf die App
APP_PASSWORD = "dein-passwort"
